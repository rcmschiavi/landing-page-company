---
import { highlights } from '../data/stack';

// Loose 5-column grid with jitter, denser toward the edges and right so
// the faded chips stay light behind the hero copy. Drift is ±15px;
// keep left ≤ ~84% so wide chips don't clip mid-word.
const slots = [
  { left: '4%', top: '8%' },
  { left: '22%', top: '4%' },
  { left: '42%', top: '10%' },
  { left: '62%', top: '5%' },
  { left: '80%', top: '12%' },
  { left: '84%', top: '30%' },
  { left: '68%', top: '26%' },
  { left: '50%', top: '30%' },
  { left: '30%', top: '24%' },
  { left: '8%', top: '30%' },
  { left: '76%', top: '46%' },
  { left: '58%', top: '52%' },
  { left: '38%', top: '46%' },
  { left: '14%', top: '52%' },
  { left: '82%', top: '66%' },
  { left: '66%', top: '72%' },
  { left: '46%', top: '78%' },
  { left: '26%', top: '72%' },
  { left: '6%', top: '80%' },
  { left: '84%', top: '88%' },
];
---

<div
  class="floating-skills pointer-events-none absolute inset-0 hidden overflow-hidden opacity-30 md:block"
  aria-hidden="true"
>
  {
    highlights.slice(0, slots.length).map((skill, i) => (
      <span
        class="floating-skill absolute rounded-full border border-accent/30 bg-zinc-900/70 px-4 py-2 text-lg whitespace-nowrap text-accent"
        style={`left:${slots[i].left}; top:${slots[i].top}; animation-delay:-${i}s;`}
      >
        {skill}
      </span>
    ))
  }
</div>

<style>
  .floating-skill {
    animation: float 10s ease-in-out infinite alternate;
    will-change: translate;
  }
  @keyframes float {
    0% {
      translate: 0 0;
      rotate: -3deg;
    }
    50% {
      translate: -15px -15px;
      rotate: 3deg;
    }
    100% {
      translate: 15px 15px;
      rotate: -3deg;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-skill {
      animation: none;
      rotate: none;
      translate: none;
    }
  }
</style>
