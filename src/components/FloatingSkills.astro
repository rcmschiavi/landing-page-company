---
import { highlights } from '../data/stack';

// Hero backdrop with scroll parallax: chips drift continuously and, in
// browsers with scroll-driven animations, rise at different speeds as
// the hero scrolls out of view. Loose 5-column grid with jitter; drift
// is ±15px; keep left ≤ ~84% so wide chips don't clip mid-word.
const slots = [
  { left: '4%', top: '8%' },
  { left: '22%', top: '4%' },
  { left: '42%', top: '10%' },
  { left: '62%', top: '5%' },
  { left: '80%', top: '12%' },
  { left: '84%', top: '30%' },
  { left: '68%', top: '26%' },
  { left: '50%', top: '30%' },
  { left: '30%', top: '24%' },
  { left: '8%', top: '30%' },
  { left: '76%', top: '46%' },
  { left: '58%', top: '52%' },
  { left: '38%', top: '46%' },
  { left: '14%', top: '52%' },
  { left: '82%', top: '66%' },
  { left: '66%', top: '72%' },
  { left: '46%', top: '78%' },
  { left: '26%', top: '72%' },
  { left: '6%', top: '80%' },
  { left: '84%', top: '88%' },
];

// Deterministic per-chip parallax distance (40–160px) for depth.
const drift = (i: number) => 40 + ((i * 37) % 121);
---

<div
  class="floating-skills pointer-events-none absolute inset-0 hidden overflow-hidden opacity-30 md:block"
  aria-hidden="true"
>
  {
    highlights.slice(0, slots.length).map((skill, i) => (
      <span
        class="floating-skill absolute rounded-full border border-accent/30 bg-zinc-900/70 px-4 py-2 text-lg whitespace-nowrap text-accent"
        style={`left:${slots[i].left}; top:${slots[i].top}; --delay:-${i}s; --drift:-${drift(i)}px;`}
      >
        {skill}
      </span>
    ))
  }
</div>

<style>
  .floating-skills {
    view-timeline-name: --skills-exit;
  }
  .floating-skill {
    animation: float 10s ease-in-out infinite alternate;
    animation-delay: var(--delay);
    will-change: translate;
  }
  /* Scroll parallax where supported: as the hero exits the viewport,
     each chip rises by its own --drift. Uses transform, which composes
     with the translate/rotate drift; other browsers keep the drift only. */
  @supports (animation-timeline: view()) {
    .floating-skill {
      animation:
        float 10s ease-in-out infinite alternate,
        parallax linear both;
      animation-delay: var(--delay), 0s;
      animation-timeline: auto, --skills-exit;
      animation-range: normal, exit;
    }
  }
  @keyframes float {
    0% {
      translate: 0 0;
      rotate: -3deg;
    }
    50% {
      translate: -15px -15px;
      rotate: 3deg;
    }
    100% {
      translate: 15px 15px;
      rotate: -3deg;
    }
  }
  @keyframes parallax {
    to {
      transform: translateY(var(--drift));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-skill {
      animation: none;
      rotate: none;
      translate: none;
      transform: none;
    }
  }
</style>
