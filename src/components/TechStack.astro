---
import Section from './Section.astro';
import { stack } from '../data/stack';
---

<Section id="stack" eyebrow="Tech Stack" title="Tools I ship with">
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {
      stack.map((group) => (
        <div>
          <h3 class="text-sm font-semibold tracking-wide uppercase text-zinc-400">
            {group.label}
          </h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1.5 text-sm text-zinc-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
