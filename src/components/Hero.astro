---
import { site } from '../data/site';
---

<section id="top" class="py-24 md:py-36">
  <div class="mx-auto max-w-5xl px-6">
    <p class="text-sm font-semibold tracking-widest uppercase text-accent">
      {site.role} · Contract & Staff Augmentation
    </p>
    <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-white md:text-6xl">
      I build and modernize the backend systems behind banking and payments products.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-zinc-400">
      I'm a senior software engineer with 6+ years building production systems in Node.js, Java,
      and Python — banking APIs, KYC onboarding, payments, and legacy modernization for fintechs.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-4">
      <a
        href={`mailto:${site.email}`}
        class="rounded-md bg-accent px-6 py-3 font-semibold text-zinc-950 transition hover:opacity-90 focus-visible:ring-2 focus-visible:ring-white"
      >
        Email me
      </a>
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md border border-zinc-700 px-6 py-3 font-semibold text-zinc-200 transition hover:border-zinc-500 hover:text-white focus-visible:ring-2 focus-visible:ring-accent"
      >
        LinkedIn
      </a>
    </div>
    <p class="mt-8 text-sm text-zinc-400">
      Working remotely from {site.location} · US/EU-friendly hours · Contracting through {site.companyName}
    </p>
  </div>
</section>
