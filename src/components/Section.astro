---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
}

const { id, eyebrow, title } = Astro.props;
---

<section id={id} class="scroll-mt-20 py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <p class="text-sm font-semibold tracking-widest uppercase text-accent">{eyebrow}</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight text-white md:text-4xl">{title}</h2>
    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>
