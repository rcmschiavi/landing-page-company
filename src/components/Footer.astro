---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-800">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-zinc-400 md:flex-row"
  >
    <p>© {year} {site.companyName} · {site.ownerName}, {site.role}</p>
    <a
      href={site.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="transition hover:text-white focus-visible:ring-2 focus-visible:ring-accent"
    >
      LinkedIn
    </a>
  </div>
</footer>
