---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — ${site.ownerName}`}
  description={post.data.description ?? site.seo.description}
>
  <Header />
  <main class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <a href="/blog" class="text-sm text-zinc-400 transition hover:text-white">&larr; All posts</a>
    <p class="mt-8 text-sm font-semibold tracking-widest uppercase text-accent">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-white md:text-5xl">
      {post.data.title}
    </h1>
    {
      post.data.heroImage && (
        <Image
          src={post.data.heroImage}
          alt=""
          widths={[640, 960, 1280]}
          sizes="(min-width: 768px) 720px, 100vw"
          class="mt-10 w-full rounded-lg border border-zinc-800"
          loading="eager"
        />
      )
    }
    <article
      class="prose prose-invert prose-zinc mt-10 max-w-none prose-headings:text-white prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-code:text-zinc-200"
    >
      <Content />
    </article>
  </main>
  <Footer />
</BaseLayout>
