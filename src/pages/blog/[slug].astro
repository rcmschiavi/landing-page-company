---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, older: posts[i - 1] ?? null, newer: posts[i + 1] ?? null },
  }));
}

const { post, older, newer } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — ${site.ownerName}`}
  description={post.data.description ?? site.seo.description}
>
  <Header />
  <main class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <a href="/blog" class="text-sm text-zinc-400 transition hover:text-white">&larr; All posts</a>
    <p class="mt-8 text-sm font-semibold tracking-widest uppercase text-accent">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-white md:text-5xl">
      {post.data.title}
    </h1>
    {
      post.data.heroImage && (
        <Image
          src={post.data.heroImage}
          alt=""
          widths={[640, 960, 1280]}
          sizes="(min-width: 768px) 720px, 100vw"
          class="mt-10 w-full rounded-lg border border-zinc-800"
          loading="eager"
        />
      )
    }
    <article
      class="prose prose-invert prose-zinc md:prose-lg mt-10 max-w-none prose-headings:text-white prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-code:text-zinc-200"
    >
      <Content />
    </article>
    {
      (older || newer) && (
        <nav
          class="mt-16 flex flex-col justify-between gap-6 border-t border-zinc-800 pt-8 sm:flex-row"
          aria-label="Post navigation"
        >
          {older ? (
            <a href={`/blog/${older.id}/`} class="group max-w-sm">
              <span class="text-xs font-semibold tracking-wide uppercase text-zinc-500">
                &larr; Older
              </span>
              <span class="mt-1 block font-semibold text-zinc-300 transition group-hover:text-white">
                {older.data.title}
              </span>
            </a>
          ) : (
            <span />
          )}
          {newer && (
            <a href={`/blog/${newer.id}/`} class="group max-w-sm sm:text-right">
              <span class="text-xs font-semibold tracking-wide uppercase text-zinc-500">
                Newer &rarr;
              </span>
              <span class="mt-1 block font-semibold text-zinc-300 transition group-hover:text-white">
                {newer.data.title}
              </span>
            </a>
          )}
        </nav>
      )
    }
  </main>
  <Footer />
</BaseLayout>
