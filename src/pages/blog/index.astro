---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';
import { formatDate } from '../../utils/date';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title={`Blog — ${site.ownerName}`}
  description="Notes on backend development, infrastructure, and AI."
>
  <Header />
  <main class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <p class="text-sm font-semibold tracking-widest uppercase text-accent">Blog</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-white md:text-5xl">
      Notes from the backend
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-zinc-400">
      Writing about backend development, infrastructure, and whatever I'm learning along the way.
    </p>

    {
      posts.length === 0 ? (
        <p class="mt-16 text-zinc-400">Posts coming soon.</p>
      ) : (
        <ul class="mt-16 space-y-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}/`}
                class="block rounded-lg border border-zinc-800 bg-zinc-900/50 p-6 transition hover:border-zinc-600"
              >
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-sm text-zinc-400"
                >
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="mt-2 text-xl font-bold text-white">{post.data.title}</h2>
                {post.data.description && (
                  <p class="mt-2 text-zinc-400">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
  <Footer />
</BaseLayout>
